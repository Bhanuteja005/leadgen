# Backend environment – copy to .env and fill in values

PORT=8000
API_KEY=dev-api-key-change-in-production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/leadgen-db?retryWrites=true&w=majority

# AfterShip email-verifier Go server
EMAIL_VERIFIER_URL=http://localhost:8080

# Apify – LinkedIn scraping
APIFY_API_KEY=
# Actor that accepts { url, maxItems } for company employees
# Alternatives: harvestapi~linkedin-company-employees, curious_coder~linkedin-company-employees-search
APIFY_ACTOR_ID=harvestapi~linkedin-company-employees

# Hunter.io (optional – free tier: 25 domain searches/month)
HUNTER_API_KEY=

# Maximum concurrent job pipelines (default 3)
MAX_CONCURRENT_JOBS=3
